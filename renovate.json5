{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',

  extends: [
    'config:recommended'
  ],

  platform: 'github',

  baseBranches: [
    'main'
  ],

  packageRules: [
    {
      matchPackageNames: ['*'],
      automerge: true,
      automergeType: 'pr'
    }
  ],

  automerge: true,
  automergeType: 'pr',
  platformAutomerge: true,

  separateMajorMinor: true
}
